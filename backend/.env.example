APP_NAME=AccuLearn
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=acculearn
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

SANCTUM_STATEFUL_DOMAINS=localhost:5173
SESSION_DOMAIN=localhost

# Moodle Web Services — leave blank to use the built-in sample data fallback.
# When set, MoodleService POSTs to {MOODLE_BASE_URL}/webservice/rest/server.php.
MOODLE_BASE_URL=
MOODLE_TOKEN=
MOODLE_FORMAT=json
MOODLE_TIMEOUT=30
MOODLE_RETRIES=2

# OpenAI — leave blank to use the grounded deterministic feedback fallback.
# When set, OpenAIService calls Chat Completions for tutor feedback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT=20
